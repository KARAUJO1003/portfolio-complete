{
  "name": "@portfolio/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @portfolio/contracts build && pnpm --filter @portfolio/feature-flags build && pnpm --filter @portfolio/permissions build && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "seed:initial": "tsx scripts/seed-initial-portfolio.ts",
    "generate:module": "node scripts/generate-module.mjs"
  },
  "dependencies": {
    "@portfolio/config": "workspace:*",
    "@portfolio/contracts": "workspace:*",
    "@portfolio/feature-flags": "workspace:*",
    "@portfolio/permissions": "workspace:*",
    "bcryptjs": "^2.0.0",
    "cookie-parser": "^1.0.0",
    "cors": "^2.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "multer": "^1.0.0",
    "resend": "^6.17.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.0.0",
    "@types/cookie-parser": "^1.0.0",
    "@types/cors": "^2.0.0",
    "@types/express": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^1.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
