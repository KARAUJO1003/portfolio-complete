{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@portfolio/contracts": [
        "../../packages/contracts/src/index.ts"
      ],
      "@portfolio/permissions": [
        "../../packages/permissions/src/index.ts"
      ],
      "@portfolio/feature-flags": [
        "../../packages/feature-flags/src/index.ts"
      ],
      "@portfolio/config": [
        "../../packages/config/src/index.ts"
      ],
      "@portfolio/http-client": [
        "../../packages/http-client/src/index.ts"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
