{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@portfolio/contracts": ["packages/contracts/src/index.ts"],
      "@portfolio/permissions": ["packages/permissions/src/index.ts"],
      "@portfolio/feature-flags": ["packages/feature-flags/src/index.ts"],
      "@portfolio/config": ["packages/config/src/index.ts"],
      "@portfolio/http-client": ["packages/http-client/src/index.ts"]
    }
  }
}
